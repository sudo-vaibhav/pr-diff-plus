{
  "name": "pr-diff-plus",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "lint:firefox": "web-ext lint --source-dir=extension --warnings-as-errors=false",
    "fixture:capture": "node tests/fixtures/_capture.mjs",
    "test:all": "vitest run && playwright test && npm run lint:firefox"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "playwright": "^1.59.1",
    "vitest": "^2.1.0",
    "web-ext": "^10.1.0"
  }
}
